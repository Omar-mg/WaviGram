# Copy to .env to override defaults

# App
VITE_API_URL=http://localhost:3000
VITE_APP_NAME=WaviGram

# Backend (API)
PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=wavigram
# Set to false in production to use migrations
DB_SYNCHRONIZE=true

# JWT
JWT_ACCESS_SECRET=your_access_token_secret_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional: Redis (for Socket.IO adapter and caching)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD= # if needed