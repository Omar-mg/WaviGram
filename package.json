{
  "name": "wavigram",
  "version": "0.1.0",
  "private": true,
  "description": "WaviGram — Where Conversations Meet Community. A modern social platform.",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @wavigram/web dev",
    "build": "pnpm -r --filter=!@wavigram/api build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css}\"",
    "clean": "pnpm -r exec rm -rf node_modules dist .turbo .next"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "typescript": "^5.6.3"
  }
}
